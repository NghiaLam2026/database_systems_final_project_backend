# Copy to .env and fill in your values. Do not commit .env.

# -----------------------------------------------------------------------------
# Database (used by Alembic and the FastAPI backend)
# -----------------------------------------------------------------------------
# Example: postgresql+psycopg2://user:password@localhost:5432/pcbuild_db
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/your_db_name

# -----------------------------------------------------------------------------
# Backend (FastAPI) – JWT & app config
# -----------------------------------------------------------------------------
# Secret used to sign JWT tokens. Use a long random string in production.
SECRET_KEY=change-me-in-production

# JWT algorithm (usually HS256)
ALGORITHM=HS256

# How long access tokens are valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated allowed origins for CORS, or * for all (e.g. React dev server)
CORS_ORIGINS=http://localhost:3000

# Set to true to enable debug mode (e.g. SQL echo, more verbose errors)
DEBUG=false

# -----------------------------------------------------------------------------
# Bootstrap Admin (required for the first admin)
# -----------------------------------------------------------------------------
# If ADMIN_EMAIL is set, the app will ensure this admin exists in the database
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# -----------------------------------------------------------------------------
# Gemini (chat) — Pydantic AI + Google Gemini (Generative Language API)
# -----------------------------------------------------------------------------
# https://ai.pydantic.dev/models/google/
GEMINI_API_KEY=
# Optional override (default in code is gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Chat guardrails (input filter before any LLM call)
# -----------------------------------------------------------------------------
# CHAT_GUARDRAIL_ENABLED=true
# Comma-separated extra substrings to block (case-insensitive), min 3 chars each
# CHAT_GUARDRAIL_EXTRA_PHRASES=some phrase,another phrase
# CHAT_GUARDRAIL_MAX_MESSAGE_LENGTH=32000